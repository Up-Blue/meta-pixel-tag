// Meta Pixel Tag by Up Blue — v1.2.0
// Browser-side companion to "Meta Conversion API Tag by Up Blue"

var log = require('logToConsole');
var copyFromDataLayer = require('copyFromDataLayer');
var copyFromWindow = require('copyFromWindow');
var setInWindow = require('setInWindow');
var callInWindow = require('callInWindow');
var aliasInWindow = require('aliasInWindow');
var createQueue = require('createQueue');
var injectScript = require('injectScript');
var makeString = require('makeString');
var makeNumber = require('makeNumber');

// ─── Constants ────────────────────────────────────────────────────────────────

var PARTNER_AGENT = 'upblue-GTM-WebPixel-1.0.0';

// Same mapping as CAPI tag for consistency
var GA4_TO_META_EVENT = {
  page_view: 'PageView',
  add_payment_info: 'AddPaymentInfo',
  add_to_cart: 'AddToCart',
  add_to_wishlist: 'AddToWishlist',
  sign_up: 'CompleteRegistration',
  begin_checkout: 'InitiateCheckout',
  generate_lead: 'Lead',
  purchase: 'Purchase',
  search: 'Search',
  view_item: 'ViewContent',
  contact: 'Contact',
  customize_product: 'CustomizeProduct',
  donate: 'Donate',
  find_location: 'FindLocation',
  schedule: 'Schedule',
  start_trial: 'StartTrial',
  submit_application: 'SubmitApplication',
  subscribe: 'Subscribe',
  'gtm4wp.addProductToCartEEC': 'AddToCart',
  'gtm4wp.productClickEEC': 'ViewContent',
  'gtm4wp.checkoutOptionEEC': 'InitiateCheckout',
  'gtm4wp.checkoutStepEEC': 'AddPaymentInfo',
  'gtm4wp.orderCompletedEEC': 'Purchase'
};

// Non-e-commerce GA4 events and GTM internal events — always skipped
var ALWAYS_SKIP = {
  'gtm.js': true,
  'gtm.dom': true,
  'gtm.load': true,
  user_engagement: true,
  scroll: true,
  form_start: true,
  form_submit: true,
  first_visit: true,
  session_start: true,
  click: true
};

// GA4 events with no standard Meta Pixel equivalent — always skipped in auto mode.
// To track any of these, create a separate tag instance with Manual mode.
var GA4_EVENTS_TO_SKIP = {
  view_item_list: true,
  select_item: true,
  select_promotion: true,
  view_promotion: true,
  view_cart: true,
  remove_from_cart: true,
  add_shipping_info: true,
  refund: true
};

function shouldSkipEvent(ga4Event) {
  if (ALWAYS_SKIP[ga4Event]) return true;
  if (GA4_EVENTS_TO_SKIP[ga4Event]) return true;
  return false;
}

var META_STANDARD_EVENTS = {
  PageView: true,
  AddPaymentInfo: true,
  AddToCart: true,
  AddToWishlist: true,
  CompleteRegistration: true,
  Contact: true,
  CustomizeProduct: true,
  Donate: true,
  FindLocation: true,
  InitiateCheckout: true,
  Lead: true,
  Purchase: true,
  Schedule: true,
  Search: true,
  StartTrial: true,
  SubmitApplication: true,
  Subscribe: true,
  ViewContent: true
};

var eventsWithNumItems = { InitiateCheckout: true, Purchase: true };

// Per-event allowed parameters (Meta Pixel documentation reference)
// https://developers.facebook.com/docs/meta-pixel/reference
var EVENT_ALLOWED_PARAMS = {
  PageView: {},
  AddPaymentInfo: { content_category:1, content_ids:1, contents:1, currency:1, value:1 },
  AddToCart: { content_category:1, content_ids:1, content_name:1, content_type:1, contents:1, currency:1, value:1 },
  AddToWishlist: { content_category:1, content_ids:1, content_name:1, contents:1, currency:1, value:1 },
  CompleteRegistration: { content_name:1, currency:1, status:1, value:1 },
  Contact: {},
  CustomizeProduct: {},
  Donate: {},
  FindLocation: {},
  InitiateCheckout: { content_category:1, content_ids:1, contents:1, currency:1, num_items:1, value:1 },
  Lead: { content_category:1, content_name:1, currency:1, value:1 },
  Purchase: { content_category:1, content_ids:1, content_name:1, content_type:1, contents:1, currency:1, num_items:1, value:1 },
  Schedule: {},
  Search: { content_category:1, content_ids:1, content_type:1, contents:1, currency:1, search_string:1, value:1 },
  StartTrial: { currency:1, predicted_ltv:1, value:1 },
  SubmitApplication: {},
  Subscribe: { currency:1, predicted_ltv:1, value:1 },
  ViewContent: { content_category:1, content_ids:1, content_name:1, content_type:1, contents:1, currency:1, value:1 }
};

// ─── Helpers ──────────────────────────────────────────────────────────────────

function deduplicateArray(arr) {
  var seen = {};
  var result = [];
  for (var i = 0; i < arr.length; i++) {
    var key = makeString(arr[i]);
    if (!seen[key]) {
      seen[key] = true;
      result.push(arr[i]);
    }
  }
  return result;
}

function mergeObjectProperties(target) {
  if (data.objectProps && data.objectProps.length > 0) {
    for (var i = 0; i < data.objectProps.length; i++) {
      var prop = data.objectProps[i];
      if (prop.name) {
        target[prop.name] = prop.value;
      }
    }
  }
  return target;
}

// Filter custom data to only include parameters documented for a given standard event.
// Custom events (not in EVENT_ALLOWED_PARAMS) pass all params through unfiltered.
function filterParamsForEvent(eventName, cd) {
  var allowed = EVENT_ALLOWED_PARAMS[eventName];
  if (!allowed) return cd;

  var filtered = {};
  for (var key in cd) {
    if (allowed[key]) {
      filtered[key] = cd[key];
    }
  }
  return filtered;
}

// ─── fbq initialization ──────────────────────────────────────────────────────

function getFbq() {
  // Return existing fbq if already loaded (e.g. by another tag)
  var fbq = copyFromWindow('fbq');
  if (fbq) return fbq;

  // Create proxy function that queues calls until fbevents.js loads
  setInWindow('fbq', function() {
    var callMethod = copyFromWindow('fbq.callMethod.apply');
    if (callMethod) {
      callInWindow('fbq.callMethod.apply', null, arguments);
    } else {
      callInWindow('fbq.queue.push', arguments);
    }
  });
  aliasInWindow('_fbq', 'fbq');
  createQueue('fbq.queue');

  return copyFromWindow('fbq');
}

function initPixel(fbq, pixelId) {
  // Disable automatic configuration BEFORE init
  if (data.disableAutoConfig) {
    fbq('set', 'autoConfig', false, pixelId);
  }

  // Disable push state tracking (SPA) — GTM triggers handle routing
  setInWindow('fbq.disablePushState', true);

  // Initialize pixel
  fbq('init', pixelId);

  // Set agent string
  fbq('set', 'agent', PARTNER_AGENT, pixelId);
}

// ─── Build custom data from ecommerce dataLayer ──────────────────────────────

function buildCustomDataFromEcommerce(eventName) {
  var ecommerce = copyFromDataLayer('ecommerce', 1);
  var cd = {};

  if (!ecommerce || !ecommerce.items || !ecommerce.items[0]) {
    // No ecommerce data — still try value/currency from ecommerce root
    if (ecommerce) {
      if (ecommerce.value) cd.value = makeNumber(ecommerce.value);
      if (ecommerce.currency) cd.currency = ecommerce.currency;
      if (ecommerce.search_term) cd.search_string = ecommerce.search_term;
    }
    return cd;
  }

  var items = ecommerce.items;
  var collectedIds = [];
  var valueFromItems = 0;
  var currencyFromItems = '';

  cd.contents = [];
  cd.content_type = 'product';

  if (eventsWithNumItems[eventName]) {
    cd.num_items = items.length;
  }

  currencyFromItems = items[0].currency || '';

  // Single item: set content_name and content_category
  if (!items[1]) {
    if (items[0].item_name) cd.content_name = items[0].item_name;
    if (items[0].item_category) cd.content_category = items[0].item_category;
    if (items[0].price) {
      cd.value = items[0].quantity ?
        items[0].quantity * makeNumber(items[0].price) :
        makeNumber(items[0].price);
    }
  }

  for (var i = 0; i < items.length; i++) {
    var item = items[i];
    var content = {};
    var itemId;

    if (item.item_id) {
      itemId = makeString(item.item_id);
    } else if (item.item_name) {
      itemId = makeString(item.item_name);
    }

    if (itemId) {
      content.id = itemId;
      collectedIds.push(itemId);
    }

    content.quantity = item.quantity || 1;
    if (item.item_name) content.title = item.item_name;
    if (item.item_brand) content.brand = item.item_brand;
    if (item.item_category) content.category = item.item_category;
    if (item.price) {
      content.item_price = makeNumber(item.price);
      valueFromItems += item.quantity ?
        item.quantity * content.item_price :
        content.item_price;
    }

    cd.contents.push(content);
  }

  if (collectedIds.length > 0) {
    cd.content_ids = deduplicateArray(collectedIds);
  }

  // Value: prefer ecommerce.value over calculated
  if (ecommerce.value) {
    cd.value = makeNumber(ecommerce.value);
  } else if (!cd.value && valueFromItems) {
    cd.value = valueFromItems;
  }

  // Currency
  if (ecommerce.currency) {
    cd.currency = ecommerce.currency;
  } else if (currencyFromItems) {
    cd.currency = currencyFromItems;
  }

  // Additional fields
  if (ecommerce.search_term) cd.search_string = ecommerce.search_term;

  // Purchase defaults
  if (eventName === 'Purchase') {
    if (!cd.currency) cd.currency = 'USD';
    if (!cd.value) cd.value = 0;
  }

  return cd;
}

// ─── Main ─────────────────────────────────────────────────────────────────────

var pixelId = makeString(data.pixelId);
var eventId = data.eventId || '';

// ─── Initialize fbq and preload fbevents.js ─────────────────────────────────
// Runs BEFORE event processing so fbevents.js starts downloading as early as
// possible — even for skipped events.  This gives the browser Pixel a head
// start over server-side CAPI and prevents Meta from hiding browser-sent
// events during deduplication.

var fbq = getFbq();
fbq('consent', 'grant');

var initIds = copyFromWindow('_fbq_gtm_ids') || [];
if (initIds.indexOf(pixelId) === -1) {
  initPixel(fbq, pixelId);
  initIds.push(pixelId);
  setInWindow('_fbq_gtm_ids', initIds, true);
}

injectScript('https://connect.facebook.net/en_US/fbevents.js', data.gtmOnSuccess, data.gtmOnFailure, 'fbPixel');

// ─── Determine event ──────────────────────────────────────────────────────────

var eventName;
var customData = {};

if (data.eventSetup === 'auto') {
  // ── Auto mode: inherit from GA4 ──
  var ga4Event = copyFromDataLayer('event', 2);

  if (!ga4Event) {
    log('Meta Pixel (Up Blue): No event found in dataLayer, skipping.');
    return;
  }

  if (shouldSkipEvent(ga4Event)) {
    log('Meta Pixel (Up Blue): Skipping event "' + ga4Event + '" — no Meta standard equivalent.');
    return;
  }

  // Map GA4 event to Meta event
  eventName = GA4_TO_META_EVENT[ga4Event];
  if (!eventName) {
    // Unknown GA4 event → send as custom event
    eventName = ga4Event;
  }

  // Build custom data from ecommerce
  customData = buildCustomDataFromEcommerce(eventName);

  // Filter to only Meta-documented params for standard events
  if (META_STANDARD_EVENTS[eventName]) {
    customData = filterParamsForEvent(eventName, customData);
  }

  // Object Properties override after filtering (always pass through)
  mergeObjectProperties(customData);

} else {
  // ── Manual mode ──
  if (data.metaEventKind === 'custom') {
    eventName = data.customEventName;
  } else {
    eventName = data.predefinedEvent;
  }

  // Use Object Properties as the custom data
  mergeObjectProperties(customData);
}

// ─── Fire event ───────────────────────────────────────────────────────────────

var options = {};
if (eventId) {
  options.eventID = eventId;
}

var isStandard = META_STANDARD_EVENTS[eventName];

var hasCustomData = false;
for (var k in customData) {
  hasCustomData = true;
  break;
}

if (isStandard) {
  fbq('trackSingle', pixelId, eventName, hasCustomData ? customData : {}, options);
} else {
  fbq('trackSingleCustom', pixelId, eventName, hasCustomData ? customData : {}, options);
}

log('Meta Pixel (Up Blue): Fired "' + eventName + '" for Pixel ' + pixelId +
    (eventId ? ' (event_id: ' + eventId + ')' : ''));


